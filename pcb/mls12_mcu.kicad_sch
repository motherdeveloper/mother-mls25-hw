	(text "C_{L} - C_{stray} = (C_{L1} * C_{L2}) / (C_{L1} + C_{L2})\nC_{L} = 10pF, C_{stray} ~= 5pF\nC_{L1} = C_{L2} = 10pF"
		(exclude_from_sim no)
		(at 197.358 84.328 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "04fe3f85-efda-4dee-929a-567e94a7d6fd")
	)
	(text "See ST AN2867"
		(exclude_from_sim no)
		(at 197.358 78.74 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
			(href "https://www.st.com/resource/en/application_note/an2867-guidelines-for-oscillator-design-on-stm8afals-and-stm32-mcusmpus-stmicroelectronics.pdf")
		)
		(uuid "1a54bae3-91bc-459d-87f9-d46ccd7d3eba")
	)
	(text "I2C connector"
		(exclude_from_sim no)
		(at 349.25 115.57 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "1b8c715b-db4f-4fbd-a5aa-5247e4a5c7a9")
	)
	(text "g_{mcrit} = 4 * R_{ESR} * (2 * pi * F)^{2} * (C_{0} + C_{L})^{2}\n= 4 * 40 * (2 * pi * 25MHz)^{2} * (1pF + 10pF)^{2}\n= 0.48 mA/V\n\ngain_{margin} = g_{m} / g_{mcrit}\n= 7.5 mA/V / 0.48 mA/V\n= 15.7 > 5"
		(exclude_from_sim no)
		(at 197.358 96.012 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "20a8c85f-e220-4f32-8b43-e57281a71db8")
	)
